# GitHub Agent V3 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# =============================================================================
# GitHub 认证（二选一）
# =============================================================================

# 方案 A: Personal Access Token (简单，推荐个人使用)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 方案 B: GitHub App (适合团队，权限更细)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Webhook Secret（用于验证 GitHub 请求）
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# 服务配置
# =============================================================================

# 数据目录（默认 ~/github-agent-data）
GITHUB_AGENT_STORAGE__DATADIR=/path/to/data

# Redis URL（可选，默认使用本地内存队列）
GITHUB_AGENT_QUEUE__REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM 配置
# =============================================================================

# Ollama 主机（本地 GPU）
GITHUB_AGENT_LLM__OLLAMA_HOST=http://localhost:11434

# OpenClaw API Key（可选，作为 fallback）
OPENCLAW_API_KEY=sk-xxxxxxxx

# =============================================================================
# 处理配置
# =============================================================================

# 确认模式: manual(人工确认) / auto(自动确认)
GITHUB_AGENT_PROCESSING__CONFIRM_MODE=manual

# 自动确认阈值（0-1）
GITHUB_AGENT_PROCESSING__AUTO_CONFIRM_THRESHOLD=0.9

# 确认超时时间（小时，默认 7 天）
GITHUB_AGENT_PROCESSING__CONFIRM_TIMEOUT_HOURS=168

# =============================================================================
# 邮件通知（可选）
# =============================================================================

SMTP_USER=bot@example.com
SMTP_PASSWORD=your_smtp_password
ADMIN_EMAIL=admin@example.com

# =============================================================================
# 调试配置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 调试模式（启用详细日志）
AGENT_DEBUG=false